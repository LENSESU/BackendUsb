POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Opcional: si se define, la app y Alembic usan esta URL en lugar de construirla desde POSTGRES_*
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_db

# Autenticación JWT
# IMPORTANTE: Cambiar JWT_SECRET_KEY en producción por una clave aleatoria segura
# Puedes generarla con: openssl rand -hex 32
JWT_SECRET_KEY=dev-secret-key-CHANGE-IN-PRODUCTION
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
USE_REFRESH_TOKENS=true