# ==== BASE DE DATOS ====

# Credenciales de PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app_db

# Host de la base de datos
POSTGRES_HOST=localhost # default para ejecutar localmente
POSTGRES_PORT=5432

# URL de conexión completa (opcional)
# Si se define, sobreescribe las variables POSTGRES_* anteriores
# Útil para apuntar a una BD externa o en producción
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_db

# Ejecutar migraciones automáticamente al arrancar la app
RUN_MIGRATIONS_ON_STARTUP=false

# Ejecutar seed de usuarios automáticamente al arrancar la app
SEED_USERS_ON_STARTUP=false




#  ==== JWT  ====

# IMPORTANTE: Cambiar en staging/producción por una clave aleatoria segura
# Generar con: openssl rand -hex 32
JWT_SECRET_KEY=dev-secret-key-CHANGE-IN-PRODUCTION

# Algoritmo de firma del token (default: HS256)
JWT_ALGORITHM=HS256

# Duración del access token en minutos (default: 60 = 1 hora)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Duración del refresh token en días (default: 7)
REFRESH_TOKEN_EXPIRE_DAYS=7

# Habilitar refresh tokens en el login (default: true)
USE_REFRESH_TOKENS=true




# ==== EMAIL / OTP ====

# Servidor SMTP
# - Local: apunta a Mailpit (incluido en docker-compose), puerto 1025
# - Producción: reemplazar con servidor SMTP real
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM=noreply@correo.com

# Para desarrollo dejar false
MAIL_START_TLS=false

# Credenciales SMTP (vacías para Mailpit en desarrollo)
MAIL_USERNAME=
MAIL_PASSWORD=

# Tiempo de expiración del código OTP en minutos (default: 2)
OTP_EXPIRE_MINUTES=2

# Tiempo mínimo entre reenvíos de OTP en segundos (default: 15)
OTP_RESEND_COOLDOWN_SECONDS=15

#  ==== REGISTRO DE USUARIOS ====

# Dominios de correo permitidos para registrarse
ALLOWED_EMAIL_DOMAINS=["dominio.co", "domain.com"]

# ==== GOOGLE CLOUD STORAGE (ADC) ====

# Activa almacenamiento real en Google Cloud Storage para evidencias.
# false: usa adaptador in-memory (desarrollo/tests).
# true: usa bucket GCS configurado.
GCS_ENABLED=false

# ID del proyecto en GCP (opcional si ADC ya resuelve proyecto por defecto).
GCS_PROJECT_ID=

# Nombre del bucket de evidencias (obligatorio cuando GCS_ENABLED=true).
GCS_BUCKET_NAME=

# Prefijo/ruta base dentro del bucket para guardar objetos.
GCS_EVIDENCE_PREFIX=incidents/evidence

# Si true, los objetos se suben como publicos y se retorna file_url publica.
# Recomendado para produccion: false.
GCS_MAKE_PUBLIC=false
